{
  "name": "obsitero",
  "type": "module",
  "version": "0.1.1",
  "description": "Notero-style Zotero to Obsidian markdown sync plugin for research notes",
  "config": {
    "addonName": "Obsitero",
    "addonID": "obsitero@zhuhu00",
    "addonRef": "obsitero",
    "addonInstance": "Obsitero",
    "prefsPrefix": "extensions.zotero.obsitero"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zhuhu00/Obsitero.git"
  },
  "author": "zhuhu00",
  "bugs": {
    "url": "https://github.com/zhuhu00/Obsitero/issues"
  },
  "homepage": "https://github.com/zhuhu00/Obsitero#readme",
  "license": "AGPL-3.0-or-later",
  "scripts": {
    "start": "zotero-plugin serve",
    "build": "zotero-plugin build && node scripts/repack-xpi.mjs .scaffold/build/addon dist/obsitero.xpi && node scripts/verify-xpi-manifest.mjs dist/obsitero.xpi && tsc --noEmit",
    "lint:check": "prettier --check . && eslint .",
    "lint:fix": "prettier --write . && eslint . --fix",
    "release": "zotero-plugin release",
    "test": "zotero-plugin test",
    "update-deps": "npm update --save"
  },
  "dependencies": {
    "zotero-plugin-toolkit": "^5.1.2"
  },
  "devDependencies": {
    "@types/chai": "^5.2.3",
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.10.0",
    "@zotero-plugin/eslint-config": "^0.6.9",
    "chai": "^6.2.2",
    "eslint": "^9.39.2",
    "mocha": "^11.7.5",
    "prettier": "^3.8.3",
    "typescript": "^5.9.3",
    "zotero-plugin-scaffold": "^0.8.6",
    "zotero-types": "^4.1.2"
  },
  "prettier": {
    "printWidth": 80,
    "tabWidth": 2,
    "endOfLine": "lf",
    "overrides": [
      {
        "files": [
          "*.xhtml"
        ],
        "options": {
          "htmlWhitespaceSensitivity": "css"
        }
      }
    ]
  }
}
